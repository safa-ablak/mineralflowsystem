# All timestamps must be in UTC (e.g. Brussels = UTC+1, so 10:00 local = 09:00 UTC)

### **Get Access Token for Landside - ADMIN**
POST http://localhost:8180/realms/mineralflow/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

client_id=landside-client&
client_secret=lLSnkg3myPI7awUP7Km7d1Sw3we6r3CS&
username=adam&
password=admin&
grant_type=password

> {%
    client.global.set("admin_access_token", response.body.access_token);
%}

### **Get Access Token for Landside - SELLER**
POST http://localhost:8180/realms/mineralflow/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

client_id=landside-client&
client_secret=lLSnkg3myPI7awUP7Km7d1Sw3we6r3CS&
username=safa&
password=seller&
grant_type=password

> {%
    client.global.set("seller_access_token", response.body.access_token);
%}

### **Get Access Token for Landside - TRUCK_DRIVER**
POST http://localhost:8180/realms/mineralflow/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

client_id=landside-client&
client_secret=lLSnkg3myPI7awUP7Km7d1Sw3we6r3CS&
username=tyler&
password=truck_driver&
grant_type=password

> {%
    client.global.set("truck_driver_access_token", response.body.access_token);
%}

### **Get Access Token for Landside - WAREHOUSE_MANAGER**
POST http://localhost:8180/realms/mineralflow/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

client_id=landside-client&
client_secret=lLSnkg3myPI7awUP7Km7d1Sw3we6r3CS&
username=william&
password=warehouse_manager&
grant_type=password

> {%
    client.global.set("warehouse_manager_access_token", response.body.access_token);
%}

#### • **As a seller**, I want to see the available time slots for a specific day to see if I can book an appointment.
#GET http://localhost:8090/api/appointments/available-time-slots?date=2026-03-03
#Accept: application/json
#Authorization: Bearer {{seller_access_token}}
##Authorization: Bearer {{admin_access_token}}
#
#### • **As a seller**, I want to make an appointment for a truck loaded with a specific raw material, so that the truck can enter the facility during a specified arrival window.
#POST http://localhost:8090/api/appointments
#Content-Type: application/json
#Authorization: Bearer {{seller_access_token}}
##Authorization: Bearer {{admin_access_token}}
#
#{
#  "truckLicensePlate": "LLJW-999",
#  "rawMaterial": "GYPSUM",
#  "scheduledArrivalTime": "2026-03-03T14:51:55"
#}
#
#> {%
#    client.global.set("appointmentId", response.body.appointmentId);
#%}
#
