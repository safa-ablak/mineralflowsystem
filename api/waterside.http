%}

#### • **As a ship captain**, I want to input the Shipping Order and vessel information upon arrival at the loading quay, so that the necessary operations, inspection, bunkering and loading can be planned initiated.
#POST http://localhost:8090/api/shipping-orders
#Content-Type: application/json
#Authorization: Bearer {{ship_captain_access_token}}
##Authorization: Bearer {{admin_access_token}}
#
#{
#  "buyerId": "1e2ee25f-0ada-4727-8c50-6e2c305fa345",
#  "referenceId": "44444444-4444-4444-4444-444444444444",
#  "vesselNumber": "LLJW-999",
