client_id=waterside-client&
client_secret=mi7FZ0OskRoryIEhaHsXfnvE6jB2Si65&
username=steve&
password=ship_captain&
grant_type=password

> {%
    client.global.set("ship_captain_access_token", response.body.access_token);
%}

